{
  "expo": {
    "name": "PayPaddy",
    "slug": "paypaddy",
    "scheme": "paypaddy",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.paypaddy.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.paypaddy.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A1F1A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
